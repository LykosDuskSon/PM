Algoritmo "DOR DEPRESSÃO E SOFRIMENTO 2"

Var

geladeira: inteiro
porta: inteiro
uma_banana: inteiro

Inicio

escreva ("insira o primeiro numero: ")
leia (geladeira)
escreva ("insira o segundo numero: ")
leia (porta)

uma_banana <- geladeira + porta

escreva ("O valor da soma desses 2 números é de:" ,uma_banana)

Fimalgoritmo