Algoritmo "DOR_DEPRESSÃO_E_SOFRIMENTO_8"

Var

potenciado: real
potenciador: real
resultado: real

Inicio

escreva ("Insira um númro a ser potênciado: ")
leia (potenciado)
escreva ("Insira um número potênciador: ")
leia (potenciador)

resultado <- potenciado ^ potenciador

escreva ("O resultado dessa potênciação é:" ,resultado)

Fimalgoritmo