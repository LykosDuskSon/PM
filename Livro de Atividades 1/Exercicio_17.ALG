Algoritmo "DOR_DEPRESSĂO_E_SOFRIMENTO_17"

Var

usuario: caractere
senha: inteiro

Inicio

escreva ("Insira seu cargo de funcionario: ")
leia (usuario)
escreva ("Insira a senha: ")
leia (senha)

se (senha = 1234) e (usuario = "admin") entao
   escreva ("Acesso liberado")
senao
     escreva ("Acesso negado >:D")
fimse

Fimalgoritmo