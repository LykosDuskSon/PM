Algoritmo "DOR_DEPRESSĂO_E_SOFRIMENTO_4"

Var

area_geladeira: INTEIRO
largura_geladeira: INTEIRO
altura_geladeira: INTEIRO

Inicio

escreva ("insira a altura: ")
leia (altura_geladeira)

escreva ("insira a largura: ")
leia (largura_geladeira)

area_geladeira <- altura_geladeira * largura_geladeira

escreva ("A area deste objeto é:" ,area_geladeira)

Fimalgoritmo