Algoritmo "DOR_DEPRESSÃO_E_SOFRIMENTO_3"

Var

GELADEIRA: INTEIRO
GELADEIRINHA: INTEIRO
GELADEIRONA: INTEIRO

Inicio

escreva ("insira o numero que deseja ver antecesso e sucessor: ")
leia (geladeira)

geladeirinha <- geladeira - 1
geladeirona <- geladeira + 1

escreva ("O sucessor deste número é:" ,geladeirona, " e o antecessor:" ,geladeirinha)

Fimalgoritmo