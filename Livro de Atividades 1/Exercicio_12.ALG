Algoritmo "DOR_DEPRESSÃO_E_SOFRIMENTO_12"

var

idade: inteiro

Inicio

escreva ("Insira uma idade: ")
leia (idade)

se (idade <= 12) entao
   escreva ("Criança")
senao
se (idade <= 17) entao
   escreva ("Adolecente")
senao
se (idade <= 59) entao
   escreva ("Adulto")
senao
     escreva ("Idoso")

fimse
fimse
fimse
Fimalgoritmo
