Algoritmo "DOR_DEPRESSÃO_E_SOFRIMENTO_13"

Var

n: inteiro

Inicio

escreva ("Insira o número que deseja saber a classificação: ")
leia (n)

se (n < 0) entao
   escreva ("Este número é negativo.")
senao
se (n > 0) entao
   escreva ("Este número é positivo.")
senao
     escreva ("Este número é neutro.")
fimse
fimse

Fimalgoritmo