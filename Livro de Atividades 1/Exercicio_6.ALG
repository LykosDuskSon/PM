Algoritmo "DOR_DEPRESSĂO_E_SOFRIMENTO_6"

Var

nota1: real
nota2: real
nota3: real
media: real

Inicio

escreva ("Insira a 1° nota do aluno: ")
leia (nota1)
escreva ("Insira a 2° nota do aluno: ")
leia (nota2)
escreva ("Insira a 3° nota do aluno: ")
leia (nota3)

media <- (nota1 + nota2 + nota3) / 3

escreva ("A média deste aluno foi de:", media)

Fimalgoritmo